@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Re-find dependencies for consumers
find_dependency(Boost REQUIRED COMPONENTS system filesystem thread)
find_dependency(latero REQUIRED)
find_dependency(ImageMagick REQUIRED COMPONENTS Magick++ )

find_dependency(PkgConfig REQUIRED)
pkg_check_modules(GTKMM REQUIRED IMPORTED_TARGET gtkmm-3.0)
pkg_check_modules(LIBXML REQUIRED IMPORTED_TARGET libxml++-3.0)

include("${CMAKE_CURRENT_LIST_DIR}/laterographicsTargets.cmake")



